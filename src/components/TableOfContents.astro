<!-- TableOfContents: builds a TOC from article headings -->
<script>
  function buildTOC() {
    const article = document.querySelector('article.prose');
    if (!article) return;
    const headings = article.querySelectorAll('h2, h3');
    if (headings.length < 2) {
      const toc = document.getElementById('toc');
      if (toc) toc.classList.add('hidden');
      return;
    }

    const toc = document.getElementById('toc');
    const list = document.getElementById('toc-list');
    if (!toc || !list) return;

    toc.classList.remove('hidden');
    list.innerHTML = '';

    headings.forEach((heading) => {
      const id = heading.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fff-]/g, '') || '';
      heading.id = id;

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = heading.textContent;
      a.className = `block text-sm py-1 transition-colors hover:text-violet-400 ${
        heading.tagName === 'H3' ? 'pl-4 text-zinc-500' : 'text-zinc-400'
      }`;

      a.addEventListener('click', (e) => {
        e.preventDefault();
        heading.scrollIntoView({ behavior: 'smooth' });
        history.pushState(null, '', `#${id}`);
      });

      li.appendChild(a);
      list.appendChild(li);
    });

    // Highlight active heading on scroll
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = list.querySelector(`a[href="#${id}"]`);
          if (link) {
            link.classList.toggle('text-violet-400', entry.isIntersecting);
            link.classList.toggle('text-zinc-400', !entry.isIntersecting && entry.target.tagName === 'H2');
            link.classList.toggle('text-zinc-500', !entry.isIntersecting && entry.target.tagName === 'H3');
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px' }
    );

    headings.forEach((h) => observer.observe(h));
  }

  buildTOC();
  document.addEventListener('astro:page-load', buildTOC);
</script>
