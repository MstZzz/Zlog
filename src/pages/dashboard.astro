<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>控制台 — ZLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', 'Noto Sans SC', system-ui, sans-serif;
      background: #09090b; color: #d4d4d8;
    }
    ::selection { background: rgba(139, 92, 246, 0.3); color: #fff; }

    .topbar {
      position: sticky; top: 0; z-index: 50;
      backdrop-filter: blur(16px); background: rgba(9,9,11,0.85);
      border-bottom: 1px solid rgba(39,39,42,0.5);
      padding: 0 24px; height: 56px; display: flex;
      align-items: center; justify-content: space-between;
    }
    .topbar h1 { font-size: 17px; font-weight: 600; color: #fff; }
    .topbar .nav { display: flex; align-items: center; gap: 16px; }
    .topbar a { color: #8b5cf6; font-size: 13px; text-decoration: none; }
    .topbar a:hover { color: #a78bfa; }
    .topbar .logout-btn { color: #71717a; cursor: pointer; font-size: 13px; background: none; border: none; }
    .topbar .logout-btn:hover { color: #f87171; }

    .container { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
    .tabs { display: flex; gap: 0; border-bottom: 1px solid #27272a; margin-bottom: 24px; }
    .tabs button {
      padding: 10px 20px; font-size: 14px; font-weight: 500;
      background: none; border: none; color: #71717a; cursor: pointer;
      border-bottom: 2px solid transparent; transition: all .2s;
    }
    .tabs button.active { color: #8b5cf6; border-bottom-color: #8b5cf6; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* Post list */
    .post-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px; border-radius: 10px;
      background: #18181b; border: 1px solid #27272a;
      margin-bottom: 8px; transition: border .2s;
    }
    .post-item:hover { border-color: #3f3f46; }
    .post-item .info { flex: 1; min-width: 0; }
    .post-item .title { font-weight: 600; color: #fff; font-size: 14px; }
    .post-item .meta { font-size: 12px; color: #71717a; margin-top: 2px; }
    .post-item .actions { display: flex; gap: 8px; }
    .post-item .actions a {
      font-size: 12px; color: #8b5cf6; text-decoration: none;
    }
    .post-item .actions a:hover { color: #a78bfa; }

    .empty { text-align: center; padding: 48px; color: #71717a; font-size: 14px; }

    /* Editor */
    .row { display: flex; gap: 16px; }
    .row .field { flex: 1; }
    .field { margin-bottom: 16px; }
    .field label { display: block; font-size: 12px; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
    .field input, .field textarea {
      width: 100%; padding: 10px 14px; border-radius: 8px;
      background: #18181b; border: 1px solid #27272a; color: #e4e4e7;
      font-size: 14px; font-family: inherit; outline: none; transition: border .2s;
    }
    .field input:focus, .field textarea:focus { border-color: #8b5cf6; }
    .field textarea { resize: vertical; min-height: 100px; }

    .editor-layout { display: flex; gap: 20px; margin-top: 8px; }
    .editor-layout .pane { flex: 1; min-width: 0; }
    .editor-layout textarea {
      width: 100%; height: 400px; padding: 14px; border-radius: 10px;
      background: #18181b; border: 1px solid #27272a; color: #e4e4e7;
      font-size: 14px; font-family: 'SF Mono', 'Fira Code', monospace;
      line-height: 1.7; outline: none; resize: none;
    }
    .editor-layout textarea:focus { border-color: #8b5cf6; }
    .preview-pane {
      height: 400px; overflow-y: auto; padding: 14px; border-radius: 10px;
      background: #18181b; border: 1px solid #27272a; font-size: 14px; line-height: 1.8;
    }
    .preview-pane h1, .preview-pane h2, .preview-pane h3 { color: #fff; margin: 16px 0 8px; }
    .preview-pane p { color: #d4d4d8; margin: 6px 0; }
    .preview-pane a { color: #a78bfa; }
    .preview-pane code { background: #27272a; color: #c4b5fd; padding: 2px 6px; border-radius: 4px; font-size: 13px; }
    .preview-pane pre { background: #18181b; border: 1px solid #27272a; border-radius: 8px; padding: 12px; overflow-x: auto; }
    .preview-pane blockquote { border-left: 2px solid #8b5cf6; padding-left: 14px; color: #a1a1aa; margin: 12px 0; }
    .preview-pane ul, .preview-pane ol { padding-left: 24px; color: #d4d4d8; }
    .preview-pane img { max-width: 100%; border-radius: 8px; }

    .btn-primary {
      padding: 10px 24px; border-radius: 10px; cursor: pointer;
      background: #8b5cf6; color: #fff; font-size: 14px; font-weight: 600;
      border: none; transition: background .2s;
    }
    .btn-primary:hover { background: #7c3aed; }
    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    #toast {
      position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%);
      padding: 12px 24px; border-radius: 10px; font-size: 14px;
      z-index: 999; opacity: 0; transition: opacity .3s; pointer-events: none;
    }
    #toast.success { background: #065f46; color: #a7f3d0; opacity: 1; }
    #toast.error { background: #7f1d1d; color: #fca5a5; opacity: 1; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>✏️ 控制台</h1>
    <div class="nav">
      <a href="/" target="_blank">博客首页</a>
      <a href="/blog" target="_blank">文章列表</a>
      <button class="logout-btn" id="logout-btn">退出登录</button>
    </div>
  </div>

  <div class="container">
    <div class="tabs">
      <button class="active" data-tab="my-posts">我的文章</button>
      <button data-tab="write-post">写文章</button>
    </div>

    <!-- My Posts -->
    <div id="my-posts" class="tab-content active">
      <div id="post-list"></div>
    </div>

    <!-- Write Post -->
    <div id="write-post" class="tab-content">
      <div class="row">
        <div class="field"><label>标题 *</label><input id="etitle" placeholder="文章标题" /></div>
        <div class="field"><label>日期</label><input id="edate" type="date" /></div>
      </div>
      <div class="field"><label>描述</label><input id="edesc" placeholder="简短描述（选填）" /></div>
      <div class="field"><label>标签（用逗号分隔）</label><input id="etags" placeholder="例如: 技术, 生活" /></div>
      <div class="field">
        <label>正文 *</label>
        <div class="editor-layout">
          <div class="pane"><textarea id="emd" placeholder="在这里写 Markdown..."></textarea></div>
          <div class="pane"><div class="preview-pane" id="editor-preview"></div></div>
        </div>
      </div>
      <button id="publish-btn" class="btn-primary">📤 发布</button>
    </div>
  </div>

  <div id="toast"></div>

  <script>
    function toast(msg, type) {
      var el = document.getElementById('toast');
      if (!el) return;
      el.textContent = msg;
      el.className = type;
      setTimeout(function() { el.className = ''; }, 3000);
    }

    // ── Tabs ──
    document.querySelectorAll('.tabs button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tabs button').forEach(function(b) { b.classList.remove('active'); });
        document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
        this.classList.add('active');
        document.getElementById(this.dataset.tab).classList.add('active');
      });
    });

    // ── Logout ──
    document.getElementById('logout-btn').addEventListener('click', async function() {
      await fetch('/api/logout', { method: 'POST' });
      window.location.href = '/login';
    });

    // ── Live preview ──
    var mdTextarea = document.getElementById('emd');
    var editorPreview = document.getElementById('editor-preview');
    var previewTimer;
    mdTextarea.addEventListener('input', function() {
      clearTimeout(previewTimer);
      previewTimer = setTimeout(function() {
        editorPreview.innerHTML = marked.parse(mdTextarea.value || '*(预览将在这里显示)*');
      }, 300);
    });
    editorPreview.innerHTML = marked.parse('*(预览将在这里显示)*');
    document.getElementById('edate').value = new Date().toISOString().split('T')[0];

    // ── Publish ──
    document.getElementById('publish-btn').addEventListener('click', async function() {
      var btn = this;
      var title = document.getElementById('etitle').value.trim();
      var content = document.getElementById('emd').value.trim();
      if (!title || !content) { toast('标题和正文不能为空', 'error'); return; }
      btn.disabled = true; btn.textContent = '⏳ 发布中...';

      try {
        var res = await fetch('/api/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: title,
            description: document.getElementById('edesc').value.trim(),
            tags: document.getElementById('etags').value.split(',').map(function(t) { return t.trim(); }).filter(Boolean),
            content: content,
            source: 'editor',
            date: document.getElementById('edate').value,
          }),
        });
        var data = await res.json();
        if (data.ok) {
          toast('✅ 发布成功！', 'success');
          document.getElementById('etitle').value = '';
          document.getElementById('edesc').value = '';
          document.getElementById('etags').value = '';
          mdTextarea.value = '';
          editorPreview.innerHTML = marked.parse('*(预览将在这里显示)*');
          loadMyPosts();
        } else {
          toast('❌ ' + (data.error || '未知错误'), 'error');
        }
      } catch (e) {
        toast('❌ 网络错误', 'error');
      }
      btn.disabled = false; btn.textContent = '📤 发布';
    });

    // ── Load My Posts ──
    function loadMyPosts() {
      fetch('/api/my-posts')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var el = document.getElementById('post-list');
          if (!data.posts || data.posts.length === 0) {
            el.innerHTML = '<div class="empty">还没有文章，去"写文章"页面开始吧 ✍️</div>';
            return;
          }
          el.innerHTML = data.posts.map(function(p) {
            var date = new Date(p.date).toLocaleDateString('zh-CN');
            return '<div class="post-item">' +
              '<div class="info">' +
                '<div class="title">' + p.title + '</div>' +
                '<div class="meta">' + date + ' · ' + (p.tags || []).join(', ') + '</div>' +
              '</div>' +
              '<div class="actions">' +
                '<a href="/blog/' + p.slug + '" target="_blank">查看</a>' +
              '</div>' +
            '</div>';
          }).join('');
        });
    }

    loadMyPosts();
  </script>
</body>
</html>
