---
import { createClient } from '@supabase/supabase-js';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CodeCopyButton from '../../components/CodeCopyButton.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ReadingTime from '../../components/ReadingTime.astro';

const supabaseUrl = import.meta.env.SUPABASE_URL || '';
const supabaseAnonKey = import.meta.env.SUPABASE_ANON_KEY || '';
const supabase = createClient(supabaseUrl, supabaseAnonKey);

const { slug } = Astro.params;

const { data: post } = await supabase
  .from('posts')
  .select('*, author:author_id (id, username, display_name)')
  .eq('slug', slug)
  .single();

if (!post) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={post.title} description={post.description || ''}>
  <Header />

  <main class="max-w-6xl mx-auto px-6 pt-24 pb-8">
    <div class="flex gap-12">
      <article class="min-w-0 flex-1 max-w-3xl">
        <header class="mb-12">
          {post.tags?.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              {post.tags.map((tag: string) => (
                <a
                  href={`/blog?tag=${tag}`}
                  class="px-2.5 py-0.5 text-xs rounded-full bg-violet-500/10 text-violet-300 border border-violet-500/20 hover:bg-violet-500/20 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-tight mb-4">
            {post.title}
          </h1>
          <div class="flex items-center gap-3 text-sm text-zinc-500">
            <time datetime={post.date}>
              {new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="text-zinc-700">·</span>
            <span>{post.author?.display_name || post.author?.username || 'ZLog'}</span>
            <span class="text-zinc-700">·</span>
            <span id="reading-time" class="text-zinc-500">计算中...</span>
          </div>
        </header>

        <div class="prose prose-invert prose-zinc max-w-none
          prose-headings:text-white prose-headings:font-semibold prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6
          prose-p:text-zinc-300 prose-p:leading-relaxed
          prose-a:text-violet-400 prose-a:no-underline hover:prose-a:text-violet-300
          prose-strong:text-white prose-strong:font-semibold
          prose-blockquote:border-violet-500/50 prose-blockquote:text-zinc-400
          prose-li:text-zinc-300
          prose-img:rounded-xl prose-img:border prose-img:border-zinc-800
          prose-hr:border-zinc-800
        ">
          <div set:html={post.content} />
        </div>

        <CodeCopyButton />
        <ReadingTime />

        <!-- Comments section -->
        <div id="comments" class="mt-16 pt-8 border-t border-zinc-800/50">
          <h3 class="text-lg font-semibold text-white mb-6">评论</h3>
          <div id="comments-list"></div>
          <div id="comment-form-area" class="mt-6"></div>
        </div>

        <nav class="mt-16 pt-8 border-t border-zinc-800/50">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-200 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            返回文章列表
          </a>
        </nav>
      </article>

      <aside id="toc" class="hidden lg:block w-56 shrink-0">
        <div class="sticky top-24">
          <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4">目录</h3>
          <nav>
            <ul id="toc-list" class="space-y-0.5 border-l border-zinc-800/50 pl-4"></ul>
          </nav>
        </div>
      </aside>
    </div>

    <TableOfContents />
  </main>

  <Footer />
</BaseLayout>

<script>
  // Load comments
  const postId = '{post.id}';
  function loadComments() {
    fetch('/api/comments?post_id=' + postId)
      .then(r => r.json())
      .then(data => {
        const el = document.getElementById('comments-list');
        if (!data.comments || data.comments.length === 0) {
          el.innerHTML = '<p class="text-sm text-zinc-500">暂无评论，来写第一条吧。</p>';
          return;
        }
        el.innerHTML = data.comments.map(c => {
          const date = new Date(c.created_at).toLocaleDateString('zh-CN');
          return '<div class="mb-4 pb-4 border-b border-zinc-800/30">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<span class="text-sm font-medium text-white">' + (c.author?.display_name || c.author?.username || '匿名') + '</span>' +
              '<span class="text-xs text-zinc-600">' + date + '</span>' +
            '</div>' +
            '<p class="text-sm text-zinc-300">' + c.content + '</p>' +
          '</div>';
        }).join('');
      });
  }

  // Check auth for comment form
  function checkAuth() {
    fetch('/api/me')
      .then(r => r.json())
      .then(data => {
        const el = document.getElementById('comment-form-area');
        if (data.user) {
          el.innerHTML = '<form id="comment-form" class="flex gap-3">' +
            '<textarea id="comment-input" class="flex-1 px-3 py-2 text-sm rounded-lg bg-zinc-900 border border-zinc-700 text-zinc-200 outline-none resize-none" placeholder="写评论..." rows="2"></textarea>' +
            '<button type="submit" class="px-4 py-2 text-sm rounded-lg bg-violet-600 text-white hover:bg-violet-500 transition-colors border-none cursor-pointer font-medium self-end">发送</button>' +
            '</form>';
          document.getElementById('comment-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var input = document.getElementById('comment-input');
            var content = input.value.trim();
            if (!content) return;
            fetch('/api/comments', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ post_id: postId, content: content }),
            }).then(function(r) { return r.json(); }).then(function(res) {
              if (res.ok) { input.value = ''; loadComments(); }
            });
          });
        } else {
          el.innerHTML = '<p class="text-sm text-zinc-500"><a href="/login" class="text-violet-400 hover:text-violet-300">登录</a>后可以评论</p>';
        }
      });
  }

  loadComments();
  checkAuth();
  document.addEventListener('astro:page-load', function() { loadComments(); checkAuth(); });
</script>
