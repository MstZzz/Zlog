<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>管理后台 — ZLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <link rel="stylesheet" href="/admin/admin.css" />
</head>
<body>

<!-- ═══ Login ═══ -->
<div id="login-screen">
  <div style="color:#fff;font-size:24px;font-weight:700;margin-bottom:8px;">⚡ ZLog 管理后台</div>
  <input id="password-input" type="password" placeholder="输入管理密码" autofocus />
  <button id="login-btn">进入后台</button>
  <div id="login-error"></div>
</div>

<!-- ═══ Admin ═══ -->
<div id="admin-screen">
  <div class="topbar">
    <h1>✏️ 管理后台</h1>
    <a href="/" target="_blank">返回博客 →</a>
  </div>

  <div class="tabs">
    <button class="active" data-tab="editor-tab">写文章</button>
    <button data-tab="upload-tab">上传 .md 文件</button>
  </div>

  <!-- TAB 1: Editor -->
  <div id="editor-tab" class="tab-content active">
    <div class="row">
      <div class="field"><label>标题 *</label><input id="etitle" placeholder="文章标题" /></div>
      <div class="field"><label>日期</label><input id="edate" type="date" /></div>
    </div>
    <div class="field"><label>描述</label><input id="edesc" placeholder="简短描述（选填）" /></div>
    <div class="field"><label>标签（用逗号分隔）</label><input id="etags" placeholder="例如: 技术, 生活" /></div>
    <div class="field">
      <label>正文 * — Markdown</label>
      <div class="editor-layout">
        <div class="pane">
          <textarea id="emd" placeholder="在这里写 Markdown...&#10;&#10;## 二级标题&#10;&#10;正文内容..."></textarea>
        </div>
        <div class="pane">
          <div class="preview-pane" id="editor-preview"></div>
        </div>
      </div>
    </div>
    <button id="editor-publish" class="btn-primary">📤 发布文章</button>
  </div>

  <!-- TAB 2: Upload -->
  <div id="upload-tab" class="tab-content">
    <div class="dropzone" id="dropzone">
      <div class="icon">📁</div>
      <p>点击选择或拖拽 .md 文件到此处</p>
      <input type="file" id="file-input" accept=".md" style="display:none" />
    </div>
    <div id="file-info"></div>
    <div class="preview-pane" id="upload-preview" style="display:none;"></div>
    <button id="upload-publish" class="btn-primary" style="display:none;margin-top:20px;">📤 上传并发布</button>
  </div>
</div>

<div id="toast"></div>

<script is:inline src="/admin/admin.js"></script>

</body>
</html>
